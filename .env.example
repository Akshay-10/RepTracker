# Optional: enables Supabase authentication and cloud persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Only add this when a trusted server route needs elevated database access.
SUPABASE_SECRET_KEY=

# Optional: enables live coaching. Without it, RepForge uses its local coach.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Used when generating absolute links in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
